---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Detail Barang">
    <div class="max-w-5xl mx-auto mt-6">
        <a href="/" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-orange-600 mb-6 transition-colors">
            &larr; Kembali ke Mading
        </a>

        <div id="loading-state" class="text-center py-20">
            <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-orange-600 mb-4"></div>
            <p class="text-slate-500">Memuat detail barang...</p>
        </div>

        <div id="content-container" class="hidden grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Kolom Detail Barang -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                <div class="h-64 bg-slate-100 relative">
                    <img id="item-img" src="" alt="Foto Barang" class="w-full h-full object-cover">
                    <div id="item-badge" class="absolute top-4 right-4 px-3 py-1 rounded-full text-xs font-bold border bg-white/90 backdrop-blur-sm shadow-sm"></div>
                </div>
                <div class="p-6">
                    <div class="flex items-center space-x-2 text-xs text-slate-500 mb-3">
                        <span id="item-category" class="inline-flex items-center px-2.5 py-1 rounded-md bg-slate-100 font-medium text-slate-600"></span>
                        <span>&bull;</span>
                        <span id="item-date" class="font-medium"></span>
                    </div>
                    <h1 id="item-title" class="text-2xl font-bold text-slate-800 mb-4"></h1>
                    <div class="prose prose-sm text-slate-600 mb-6">
                        <p id="item-desc"></p>
                    </div>
                    <div class="flex items-center text-sm text-slate-500 font-medium p-3 bg-slate-50 rounded-lg border border-slate-100">
                        <svg class="w-5 h-5 mr-2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <span id="item-location"></span>
                    </div>
                </div>
            </div>

            <!-- Kolom Form Klaim -->
            <div>
                <div class="bg-orange-50 border border-orange-200 rounded-2xl p-6 shadow-sm">
                    <h2 class="text-xl font-bold text-slate-800 mb-2">Apakah ini milik Anda?</h2>
                    <p class="text-sm text-slate-600 mb-6">Ajukan klaim dengan memberikan bukti yang meyakinkan agar disetujui oleh Satpam.</p>

                    <div id="claim-alert" class="hidden p-3 rounded-lg text-sm mb-4 border"></div>

                    <form id="claim-form" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Bukti Teks (Ciri Spesifik)</label>
                            <textarea id="bukti_teks" required rows="3" class="w-full px-4 py-2 border border-orange-200 rounded-lg focus:ring-2 focus:ring-orange-500 outline-none bg-white" placeholder="Sebutkan isi rahasia di dalam dompet / ciri goresan pada barang..."></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Upload Bukti Kepemilikan (KTM / Struk)</label>
                            <input type="file" id="bukti_foto" accept="image/*" class="w-full px-4 py-2 border border-orange-200 rounded-lg focus:outline-none file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-white file:text-orange-700 hover:file:bg-orange-100 bg-white">
                        </div>
                        <button type="submit" id="claim-btn" class="w-full bg-orange-600 hover:bg-orange-700 text-white font-semibold py-3 rounded-lg shadow-md transition-colors mt-2">
                            Ajukan Klaim Sekarang
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</MainLayout>

<script>
    import { API_URL, fetchAPI } from '../scripts/api.js';

    document.addEventListener('DOMContentLoaded', async () => {
        const urlParams = new URLSearchParams(window.location.search);
        const itemId = urlParams.get('id');

        if (!itemId) {
            window.location.href = '/';
            return;
        }

        const loading = document.getElementById('loading-state');
        const content = document.getElementById('content-container');

        // Fetch Detail Barang
        try {
            const res = await fetchAPI(`/items/${itemId}`);
            const data = await res.json();

            if (res.ok && data.success) {
                const item = data.data;
                
                const isLost = item.post_type === 'lost';
                document.getElementById('item-img').src = item.foto ? `http://127.0.0.1:8000/storage/${item.foto}` : 'https://placehold.co/800x600/f8fafc/94a3b8?text=Tidak+Ada+Foto';
                
                const badge = document.getElementById('item-badge');
                badge.textContent = isLost ? 'Kehilangan' : 'Ditemukan';
                badge.className = `absolute top-4 right-4 px-3 py-1 rounded-full text-xs font-bold border bg-white/90 backdrop-blur-sm shadow-sm ${isLost ? 'text-red-700 border-red-200' : 'text-emerald-700 border-emerald-200'}`;
                
                document.getElementById('item-category').textContent = item.category?.nama_kategori || 'Umum';
                document.getElementById('item-date').textContent = new Date(item.tanggal_lapor).toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric'});
                document.getElementById('item-title').textContent = item.judul;
                document.getElementById('item-desc').textContent = item.deskripsi;
                document.getElementById('item-location').textContent = item.location?.nama_tempat || 'Lokasi tidak diketahui';

                loading.classList.add('hidden');
                content.classList.remove('hidden');
            } else {
                throw new Error();
            }
        } catch (err) {
            loading.innerHTML = '<p class="text-red-500">Gagal memuat detail barang atau barang tidak ditemukan.</p>';
        }

        // Submit Form Klaim
        document.getElementById('claim-form')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            // Cek login
            if (!localStorage.getItem('token')) {
                alert('Anda harus Login terlebih dahulu untuk mengajukan klaim!');
                window.location.href = '/login';
                return;
            }

            const btn = document.getElementById('claim-btn');
            const alertBox = document.getElementById('claim-alert');
            btn.textContent = 'Memproses...';
            btn.disabled = true;
            alertBox.classList.add('hidden');

            try {
                const formData = new FormData();
                formData.append('item_id', itemId);
                formData.append('bukti_teks', document.getElementById('bukti_teks').value);
                
                const fileInput = document.getElementById('bukti_foto');
                if (fileInput.files.length > 0) {
                    formData.append('bukti_foto', fileInput.files[0]);
                }

                const res = await fetchAPI('/claims', {
                    method: 'POST',
                    body: formData
                });

                const data = await res.json();

                if (res.ok && data.success) {
                    alertBox.textContent = 'Klaim berhasil diajukan! Pantau statusnya di menu Status Klaim.';
                    alertBox.className = 'bg-green-50 text-green-700 border-green-200 p-3 rounded-lg text-sm mb-4 border block';
                    document.getElementById('claim-form').reset();
                } else {
                    throw new Error(data.message || 'Gagal mengajukan klaim. (Anti-Spam aktif atau data tidak valid).');
                }
            } catch (err) {
                alertBox.textContent = err.message;
                alertBox.className = 'bg-red-50 text-red-600 border-red-200 p-3 rounded-lg text-sm mb-4 border block';
            } finally {
                btn.textContent = 'Ajukan Klaim Sekarang';
                btn.disabled = false;
            }
        });
    });
</script>
