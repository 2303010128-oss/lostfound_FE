---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Masuk">
    <div class="max-w-md mx-auto mt-10 bg-white p-8 rounded-2xl shadow-sm border border-slate-100">
        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-slate-800">Selamat Datang Kembali</h1>
            <p class="text-slate-500 mt-2 text-sm">Masuk ke akun Anda untuk mengakses fitur penuh</p>
        </div>

        <div id="error-alert" class="hidden bg-red-50 text-red-600 p-3 rounded-lg text-sm mb-6 border border-red-200"></div>

        <form id="login-form" class="space-y-5">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Email Mahasiswa / Satpam</label>
                <input type="email" id="email" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition outline-none" placeholder="nim@student.unper.ac.id">
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Password</label>
                <input type="password" id="password" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition outline-none" placeholder="••••••••">
            </div>
            <button type="submit" id="submit-btn" class="w-full bg-orange-600 hover:bg-orange-700 text-white font-semibold py-2.5 rounded-lg shadow-md transition-colors flex justify-center items-center">
                <span>Masuk Sekarang</span>
            </button>
        </form>

        <p class="mt-6 text-center text-sm text-slate-600">
            Belum punya akun? <a href="/register" class="text-orange-600 font-semibold hover:underline">Daftar di sini</a>
        </p>
    </div>
</MainLayout>

<script>
    import { API_URL } from '../scripts/api.js';

    document.getElementById('login-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;
        const btn = document.getElementById('submit-btn');
        const alertBox = document.getElementById('error-alert');

        // Loading state
        btn.innerHTML = '<span class="animate-pulse">Memproses...</span>';
        btn.disabled = true;
        alertBox.classList.add('hidden');

        try {
            const res = await fetch(`${API_URL}/auth/login`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({ email, password })
            });

            const data = await res.json();

            if (res.ok && data.success) {
                // Simpan token ke localStorage
                localStorage.setItem('token', data.data.token);
                
                // Ambil profil untuk mengetahui role-nya
                const profileRes = await fetch(`${API_URL}/auth/profile`, {
                    headers: { 'Authorization': `Bearer ${data.data.token}`, 'Accept': 'application/json' }
                });
                
                if (profileRes.ok) {
                    const profileData = await profileRes.json();
                    localStorage.setItem('role', profileData.data.role);
                }

                // Redirect ke beranda
                window.location.href = '/';
            } else {
                throw new Error(data.message || 'Login gagal. Periksa kembali kredensial Anda.');
            }
        } catch (err) {
            alertBox.textContent = err.message;
            alertBox.classList.remove('hidden');
        } finally {
            btn.innerHTML = '<span>Masuk Sekarang</span>';
            btn.disabled = false;
        }
    });
</script>
