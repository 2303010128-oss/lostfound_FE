---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Buat Laporan Baru">
    <div class="max-w-2xl mx-auto bg-white p-8 rounded-2xl shadow-sm border border-slate-100 mt-6">
        <h1 class="text-2xl font-bold text-slate-800 mb-2">Buat Laporan Baru</h1>
        <p class="text-slate-500 mb-8">Laporkan barang yang Anda temukan atau barang Anda yang hilang di area kampus.</p>

        <div id="alert-box" class="hidden p-4 rounded-lg text-sm mb-6 border"></div>

        <form id="report-form" class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Tipe Laporan</label>
                    <select id="post_type" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-orange-500 outline-none bg-white">
                        <option value="found">Saya Menemukan Barang (Found)</option>
                        <option value="lost">Saya Kehilangan Barang (Lost)</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Judul Singkat</label>
                    <input type="text" id="judul" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-orange-500 outline-none" placeholder="Contoh: Dompet Kulit Coklat">
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Kategori Barang</label>
                <!-- Asumsi ID 1: Elektronik, 2: Aksesoris, 3: Dokumen -->
                <select id="category_id" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-orange-500 outline-none bg-white">
                    <option value="1">Elektronik (HP, Laptop)</option>
                    <option value="2">Aksesoris (Dompet, Kunci, Tas)</option>
                    <option value="3">Dokumen Pribadi (KTP, KTM, SIM)</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Lokasi Kejadian</label>
                <!-- Asumsi ID 1: Gedung Rektorat, 2: Gedung F, 3: Perpustakaan -->
                <select id="location_id" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-orange-500 outline-none bg-white">
                    <option value="1">Gedung Rektorat</option>
                    <option value="2">Gedung F / Fakultas</option>
                    <option value="3">Perpustakaan Pusat</option>
                    <option value="4">Area Parkir</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Deskripsi Publik</label>
                <textarea id="deskripsi" required rows="3" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-orange-500 outline-none" placeholder="Ceritakan ciri-ciri umum barang tersebut..."></textarea>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Deskripsi Rahasia <span class="text-xs text-orange-600 font-normal">(Tidak tampil di publik)</span></label>
                <textarea id="deskripsi_rahasia" required rows="2" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-orange-500 outline-none bg-orange-50/50" placeholder="Sebutkan isi spesifik (misal: ada KTP atas nama Budi, berisi uang 50rb)"></textarea>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Foto Barang (Opsional)</label>
                <input type="file" id="foto" accept="image/*" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-orange-50 file:text-orange-700 hover:file:bg-orange-100">
            </div>

            <div class="pt-4 border-t border-slate-100">
                <button type="submit" id="submit-btn" class="w-full bg-orange-600 hover:bg-orange-700 text-white font-semibold py-3 rounded-lg shadow-md transition-colors flex justify-center items-center">
                    <span>Kirim Laporan</span>
                </button>
            </div>
        </form>
    </div>
</MainLayout>

<script>
    import { API_URL, fetchAPI } from '../../scripts/api.js';

    document.getElementById('report-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const btn = document.getElementById('submit-btn');
        const alertBox = document.getElementById('alert-box');
        btn.innerHTML = '<span class="animate-pulse">Mengunggah...</span>';
        btn.disabled = true;
        alertBox.classList.add('hidden');

        try {
            const formData = new FormData();
            formData.append('judul', document.getElementById('judul').value);
            formData.append('deskripsi', document.getElementById('deskripsi').value);
            formData.append('deskripsi_rahasia', document.getElementById('deskripsi_rahasia').value);
            formData.append('post_type', document.getElementById('post_type').value);
            formData.append('category_id', document.getElementById('category_id').value);
            formData.append('location_id', document.getElementById('location_id').value);
            
            // Format datetime MySQL
            const now = new Date();
            const pad = (n) => n < 10 ? '0'+n : n;
            const mysqlDate = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())} ${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;
            formData.append('tanggal_lapor', mysqlDate);

            const fileInput = document.getElementById('foto');
            if (fileInput.files.length > 0) {
                formData.append('foto', fileInput.files[0]);
            }

            const res = await fetchAPI('/items', {
                method: 'POST',
                // JANGAN set Content-Type, biarkan browser mengatur multipart/form-data dan boundary-nya
                body: formData
            });

            const data = await res.json();

            if (res.ok && data.success) {
                alertBox.textContent = 'Laporan berhasil dibuat! Mengalihkan ke beranda...';
                alertBox.className = 'bg-green-50 text-green-700 border-green-200 p-4 rounded-lg text-sm mb-6 border block';
                setTimeout(() => window.location.href = '/', 2000);
            } else {
                throw new Error(data.message || 'Gagal mengirim laporan. Coba lagi.');
            }
        } catch (err) {
            alertBox.textContent = err.message;
            alertBox.className = 'bg-red-50 text-red-600 border-red-200 p-4 rounded-lg text-sm mb-6 border block';
            btn.innerHTML = '<span>Kirim Laporan</span>';
            btn.disabled = false;
        }
    });
</script>
