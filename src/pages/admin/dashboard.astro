---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Dashboard Satpam">
    <div class="max-w-6xl mx-auto mt-6">
        <div class="flex justify-between items-center mb-6">
            <div>
                <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight mb-2">Panel Kendali Satpam</h1>
                <p class="text-slate-600">Kelola persetujuan klaim dan serah terima barang.</p>
            </div>
            <button id="refresh-btn" class="bg-white border border-slate-300 text-slate-700 px-4 py-2 rounded-lg font-medium hover:bg-slate-50 transition shadow-sm flex items-center">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                Segarkan Data
            </button>
        </div>

        <div id="admin-alert" class="hidden p-4 rounded-lg text-sm mb-6 border"></div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left text-slate-500">
                    <thead class="text-xs text-slate-700 uppercase bg-slate-50 border-b border-slate-200">
                        <tr>
                            <th scope="col" class="px-6 py-4">Mahasiswa</th>
                            <th scope="col" class="px-6 py-4">Barang</th>
                            <th scope="col" class="px-6 py-4">Bukti Klaim</th>
                            <th scope="col" class="px-6 py-4 text-center">Status</th>
                            <th scope="col" class="px-6 py-4 text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="admin-table-body">
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-slate-500 animate-pulse">Mengambil data dari server...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</MainLayout>

<script>
    import { fetchAPI } from '../../scripts/api.js';

    document.addEventListener('DOMContentLoaded', () => {
        const tbody = document.getElementById('admin-table-body');
        const refreshBtn = document.getElementById('refresh-btn');
        const alertBox = document.getElementById('admin-alert');

        function showAlert(msg, isSuccess = true) {
            alertBox.textContent = msg;
            alertBox.className = `p-4 rounded-lg text-sm mb-6 border block ${isSuccess ? 'bg-green-50 text-green-700 border-green-200' : 'bg-red-50 text-red-600 border-red-200'}`;
            setTimeout(() => alertBox.classList.add('hidden'), 5000);
        }

        async function loadClaims() {
            tbody.innerHTML = `<tr><td colspan="5" class="px-6 py-12 text-center text-slate-500 animate-pulse">Memuat...</td></tr>`;
            try {
                // Asumsi API backend menyediakan endpoint untuk melihat semua klaim (untuk Satpam)
                // Jika belum ada, Anda bisa menambahkannya di Backend nanti. Sementara kita asumsikan /claims mengembalikan semua.
                const res = await fetchAPI('/claims');
                const data = await res.json();

                if (res.ok && data.success) {
                    const claims = data.data.data || data.data;

                    if (claims.length === 0) {
                        tbody.innerHTML = `<tr><td colspan="5" class="px-6 py-12 text-center text-slate-500">Tidak ada pengajuan klaim saat ini.</td></tr>`;
                        return;
                    }

                    tbody.innerHTML = '';
                    claims.forEach(claim => {
                        let statusHtml = '';
                        let actionHtml = '';

                        if (claim.status_verif === 'pending') {
                            statusHtml = `<span class="bg-yellow-100 text-yellow-800 text-xs font-bold px-2.5 py-1 rounded border border-yellow-200">Pending</span>`;
                            actionHtml = `
                                <div class="flex justify-center space-x-2">
                                    <button onclick="verifyClaim(${claim.id}, 'approved')" class="bg-emerald-500 hover:bg-emerald-600 text-white px-3 py-1.5 rounded-lg text-xs font-semibold shadow-sm transition">Terima</button>
                                    <button onclick="verifyClaim(${claim.id}, 'rejected')" class="bg-red-500 hover:bg-red-600 text-white px-3 py-1.5 rounded-lg text-xs font-semibold shadow-sm transition">Tolak</button>
                                </div>
                            `;
                        } else if (claim.status_verif === 'approved') {
                            statusHtml = `<span class="bg-green-100 text-green-800 text-xs font-bold px-2.5 py-1 rounded border border-green-200">Disetujui</span>`;
                            actionHtml = `
                                <a href="/admin/handover?claim_id=${claim.id}&token=${claim.token_pengambilan}" class="inline-block bg-orange-600 hover:bg-orange-700 text-white px-3 py-1.5 rounded-lg text-xs font-bold shadow-sm transition whitespace-nowrap">
                                    📷 Serah Terima
                                </a>
                            `;
                        } else {
                            statusHtml = `<span class="bg-red-100 text-red-800 text-xs font-bold px-2.5 py-1 rounded border border-red-200">Ditolak</span>`;
                            actionHtml = `<span class="text-slate-400 text-xs italic">- Selesai -</span>`;
                        }

                        const tr = document.createElement('tr');
                        tr.className = 'bg-white border-b hover:bg-slate-50';
                        tr.innerHTML = `
                            <td class="px-6 py-4">
                                <div class="font-bold text-slate-800">${claim.user?.nama_lengkap || 'Mahasiswa'}</div>
                                <div class="text-xs text-slate-500">${claim.user?.email || ''}</div>
                            </td>
                            <td class="px-6 py-4 font-medium text-slate-900">${claim.item?.judul || 'Barang Dihapus'}</td>
                            <td class="px-6 py-4">
                                <p class="text-xs italic bg-slate-100 p-2 rounded">"${claim.bukti_teks}"</p>
                            </td>
                            <td class="px-6 py-4 text-center">${statusHtml}</td>
                            <td class="px-6 py-4 text-center">${actionHtml}</td>
                        `;
                        tbody.appendChild(tr);
                    });
                }
            } catch (err) {
                tbody.innerHTML = `<tr><td colspan="5" class="px-6 py-12 text-center text-red-500">Gagal mengambil data.</td></tr>`;
            }
        }

        window.verifyClaim = async function(id, status) {
            if (!confirm(`Apakah Anda yakin ingin memproses klaim ini menjadi ${status.toUpperCase()}?`)) return;
            
            try {
                const res = await fetchAPI(`/claims/${id}/verify`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });
                
                if (res.ok) {
                    showAlert(`Klaim berhasil di-${status}!`);
                    loadClaims();
                } else {
                    const data = await res.json();
                    showAlert(data.message || 'Gagal memverifikasi klaim', false);
                }
            } catch (e) {
                showAlert('Terjadi kesalahan jaringan.', false);
            }
        };

        refreshBtn.addEventListener('click', loadClaims);
        loadClaims(); // Panggilan pertama
    });
</script>
